<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.Oblivio" parent="android:Theme.Material.NoActionBar" >
        <item name="android:windowLightStatusBar">false</item>
    </style>
    <!-- Keep launch window light so cold start does not flash dark before app theme is loaded. -->
    <style name="Theme.Oblivio.Starting" parent="Theme.SplashScreen">
        <item name="android:windowBackground">@color/splash_window_background</item>
        <item name="windowSplashScreenBackground">@color/splash_window_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.Oblivio</item>
    </style>
</resources>
