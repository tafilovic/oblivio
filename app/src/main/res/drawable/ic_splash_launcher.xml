<?xml version="1.0" encoding="utf-8"?>
<!-- Inset shrinks the bitmap inside the system splash’s circular mask; edge-to-edge PNGs clip without it. -->
<inset xmlns:android="http://schemas.android.com/apk/res/android"
    android:drawable="@drawable/launcher"
    android:insetLeft="22%"
    android:insetTop="22%"
    android:insetRight="22%"
    android:insetBottom="22%" />
